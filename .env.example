# Copia este archivo como .env y coloca tu propia API key de TheMovieDB
# Consíguela gratis en: https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=74a16a9f906ef9717d3f274f2575d9ce

# API key de Groq, OBLIGATORIA para que funcione CineBot (usa Llama vía Groq, gratis).
# Consíguela en: https://console.groq.com/keys
# ⚠️ En un proyecto Vite/frontend esta key queda visible en el navegador.
#    Solo úsala así para desarrollo/pruebas, no en producción pública.
VITE_GROQ_API_KEY=
VITE_GROQ_MODEL=llama-3.3-70b-versatile
